# dawos-agent configuration
# Copy to .env and adjust values

# API authentication key — shared secret with dawu-radius
DAWOS_API_KEY=changeme-generate-a-strong-key

# Agent listen address
DAWOS_HOST=0.0.0.0
DAWOS_PORT=8470

# Node identity (auto-detected from hostname if empty)
DAWOS_NODE_NAME=

# accel-ppp settings
ACCEL_CMD=/usr/bin/accel-cmd
ACCEL_CLI_PORT=2001
ACCEL_CONFIG_PATH=/etc/accel-ppp.conf
ACCEL_SERVICE_NAME=accel-ppp

# Logging
DAWOS_LOG_LEVEL=info
